# LLM (runs locally, no API key needed)
MODEL_NAME=Qwen/Qwen2.5-1.5B-Instruct
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Inference
MAX_NEW_TOKENS=120
TEMPERATURE=0.0
MAX_RETRIES=2

# RAG
TOP_K_CHUNKS=2
CHUNK_SIZE=512
CHUNK_OVERLAP=50
POLICY_PATH=data/travel_policy.md

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
